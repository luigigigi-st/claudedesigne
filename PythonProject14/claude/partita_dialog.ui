          </item>

          <item row="1" column="0"><widget class="QLabel" name="label_squadra2"><property name="text"><string>Squadra 2:</string></property></widget></item>
          <item row="1" column="1"><widget class="QComboBox" name="combo_squadra2"/></item>
          <item row="1" column="2"><widget class="QLabel" name="label_punteggio2"><property name="text"><string>Punti:</string></property></widget></item>
          <item row="1" column="3">
           <widget class="QSpinBox" name="spin_punteggio2">
