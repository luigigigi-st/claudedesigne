        </item>
        <!--
          Nota: GPU.py valida che spin_punteggio1 + spin_punteggio2 == punteggio_max_parita.
          specialValueText "N/D" RIMOSSO perché 0 è un punteggio valido a Briscola
          (es. 0–120 è un risultato legittimo).
        -->
        <item>
