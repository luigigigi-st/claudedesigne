  <property name="styleSheet">
   <string>
QWidget#HomeWidget { background-color: #ecf0f1; }

QFrame#frame_stat {
    background-color: white;
    border: 1px solid #dce1e7;
    border-radius: 10px;
}
QLabel#lbl_num_tornei, QLabel#lbl_num_attivi,
QLabel#lbl_num_partecipanti, QLabel#lbl_num_conclusi {
    font-family: Helvetica;
    font-size: 32pt;
    font-weight: bold;
}
QLabel#lbl_num_tornei    { color: #2c3e50; }
QLabel#lbl_num_attivi    { color: #1abc9c; }
QLabel#lbl_num_partecipanti { color: #2e86c1; }
QLabel#lbl_num_conclusi  { color: #e74c3c; }

QLabel.stat_desc {
    color: #7f8c8d;
    font-family: Helvetica;
    font-size: 8pt;
    letter-spacing: 1px;
}

QFrame#frame_box {
    background-color: white;
    border: 1px solid #dce1e7;
    border-radius: 10px;
}
QLabel#lbl_box_title {
    color: #2c3e50;
    font-family: Helvetica;
    font-size: 11pt;
    font-weight: bold;
}
QListWidget {
    background-color: transparent;
    border: none;
    color: #2c3e50;
    font-family: Helvetica;
    font-size: 10pt;
}
QListWidget::item {
    padding: 7px 6px;
    border-bottom: 1px solid #ecf0f1;
}
QListWidget::item:selected {
    background-color: #eaf4fb;
    color: #2c3e50;
}

QLabel#lbl_titolo {
    color: #2c3e50;
    font-family: Helvetica;
    font-size: 20pt;
    font-weight: bold;
}
QLabel#lbl_sottotitolo {
    color: #7f8c8d;
    font-family: Helvetica;
    font-size: 10pt;
}
QPushButton#btn_regolamento {
    background-color: #2c3e50;
    color: white;
    border-radius: 8px;
    font-family: Helvetica;
    font-size: 10pt;
    font-weight: bold;
    padding: 8px 20px;
    border: none;
}
QPushButton#btn_regolamento:hover { background-color: #1a252f; }
   </string>
