<ui version="4.0">
 <class>DettagliPartecipanteDialog</class>
 <widget class="QDialog" name="DettagliPartecipanteDialog">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>600</width><height>700</height></rect>
  </property>
  <property name="windowTitle"><string>Dettagli e Modifica Partecipante</string></property>
  <property name="styleSheet">
   <string>
QDialog {
    background-color: #ecf0f1;
}
QLabel {
    color: #34495e;
    font-family: Helvetica;
    font-size: 12pt;
}
QLabel#label_dialog_title {
    color: white;
    font-family: Helvetica;
    font-size: 16pt;
    font-weight: bold;
}
QFrame#frame_header {
    background-color: #2c3e50;
}
/* Rimuove i bordi attorno ai gruppi di input */
QFrame#form_frame {
    background-color: #ffffff;
    border: 1px solid #bdc3c7; /* Mantiene un bordo esterno per l'intero form */
    border-radius: 6px;
}
QLabel.section_title { /* Style for section titles */
    color: #2c3e50;
    font-weight: bold;
    font-size: 11pt;
    border-bottom: 1px solid #bdc3c7;
    padding-bottom: 4px;
    margin-top: 10px; /* Spazio sopra il titolo della sezione */
    margin-bottom: 5px; /* Spazio sotto il titolo della sezione */
}
QLineEdit, QDateEdit {
    border: 1px solid #bdc3c7;
    border-radius: 4px;
    padding: 6px;
    font-family: Helvetica;
    font-size: 11pt;
    background-color: white;
}
QLineEdit:focus, QDateEdit:focus {
    border: 1px solid #3498db;
}
QListWidget {
    border: 1px solid #bdc3c7;
    border-radius: 4px;
    padding: 5px;
    font-family: Helvetica;
    font-size: 11pt;
    background-color: white;
}
QListWidget::item {
    padding: 3px;
}
QPushButton {
    background-color: #1abc9c;
    color: white;
    border-radius: 6px;
    font-family: Helvetica;
    font-size: 12pt;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #16a085;
}
QPushButton#btn_cancel {
    background-color: #95a5a6;
}
QPushButton#btn_cancel:hover {
    background-color: #7f8c8d;
}
   </string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout_main">
   <property name="spacing"><number>0</number></property>
   <property name="leftMargin"><number>0</number></property>
   <property name="topMargin"><number>0</number></property>
